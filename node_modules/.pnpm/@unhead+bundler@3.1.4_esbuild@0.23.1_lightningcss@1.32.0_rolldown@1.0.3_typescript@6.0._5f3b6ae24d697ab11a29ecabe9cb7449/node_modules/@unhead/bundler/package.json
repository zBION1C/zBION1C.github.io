{
  "name": "@unhead/bundler",
  "type": "module",
  "version": "3.1.4",
  "description": "Unhead build-time optimizations for Vite and Webpack.",
  "author": "Harlan Wilton <harlan@harlanzw.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/harlan-zw",
  "homepage": "https://unhead.unjs.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unjs/unhead.git",
    "directory": "packages/bundler"
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "bugs": {
    "url": "https://github.com/unjs/unhead/issues"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "default": "./dist/vite.mjs"
    },
    "./framework": {
      "types": "./dist/framework.d.ts",
      "default": "./dist/framework.mjs"
    },
    "./minify/rolldown": {
      "types": "./dist/minify/rolldown.d.ts",
      "default": "./dist/minify/rolldown.mjs"
    },
    "./minify/esbuild": {
      "types": "./dist/minify/esbuild.d.ts",
      "default": "./dist/minify/esbuild.mjs"
    },
    "./minify/lightningcss": {
      "types": "./dist/minify/lightningcss.d.ts",
      "default": "./dist/minify/lightningcss.mjs"
    }
  },
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "vite": [
        "dist/vite"
      ],
      "framework": [
        "dist/framework"
      ],
      "minify/rolldown": [
        "dist/minify/rolldown"
      ],
      "minify/esbuild": [
        "dist/minify/esbuild"
      ],
      "minify/lightningcss": [
        "dist/minify/lightningcss"
      ]
    }
  },
  "files": [
    "*.d.ts",
    "dist"
  ],
  "peerDependencies": {
    "esbuild": ">=0.17.0",
    "lightningcss": ">=1.20.0",
    "rolldown": ">=1.0.0-beta.0",
    "vite": ">=6.4.2",
    "webpack": ">=5.0.0",
    "@unhead/cli": "^3.1.4",
    "unhead": "^3.1.4"
  },
  "peerDependenciesMeta": {
    "@unhead/cli": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "lightningcss": {
      "optional": true
    },
    "rolldown": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "dependencies": {
    "@vitejs/devtools-kit": "^0.3.1",
    "magic-string": "^0.30.21",
    "oxc-parser": "^0.135.0",
    "oxc-walker": "^1.0.0",
    "ufo": "^1.6.4",
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "rollup": "^4.61.1",
    "vite": "^8.0.16",
    "unhead": "3.1.4"
  },
  "scripts": {
    "build": "unbuild",
    "stub": "unbuild --stub",
    "test:attw": "attw --pack"
  }
}